{
  "name": "skydiving-dashboard-electron-wrapper",
  "version": "1.1.18",
  "description": "Electron wrapper for Skydiving Dashboard (starts local Python feed + fullscreen app window)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "prebuild": "node -e \"const fs=require('fs');const pkg=JSON.parse(fs.readFileSync('package.json','utf8'));fs.writeFileSync('../version.json',JSON.stringify({version:pkg.version,productName:pkg.build.productName,generatedAt:new Date().toISOString()},null,2),'utf8');console.log('version.json written: '+pkg.version);\"",
    "predist": "node -e \"const fs=require('fs');const pkg=JSON.parse(fs.readFileSync('package.json','utf8'));fs.writeFileSync('../version.json',JSON.stringify({version:pkg.version,productName:pkg.build.productName,generatedAt:new Date().toISOString()},null,2),'utf8');console.log('version.json written: '+pkg.version);\""
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.grouchmedia.skydivingdashboard",
    "productName": "Skydiving Dashboard",
    "asar": true,
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../dashboard.html",
        "to": "dashboard.html"
      },
      {
        "from": "../dz_feed_server.py",
        "to": "dz_feed_server.py"
      },
      {
        "from": "../config",
        "to": "config"
      },
      {
        "from": "../version.json",
        "to": "version.json"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
